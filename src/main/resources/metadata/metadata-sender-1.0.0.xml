                   ComponentName="kafkaAdapterPlus"
                   UIElementType="Adapter"
                   IsExtension="false"
                   IsFinal="true"
                   IsPreserves="true"
                   IsDefaultGenerator="true"
                   ComponentDisplayName="KafkaAdapterPlus"
                   xmlns:gen="http://www.sap.hci.adk.com/gen"
                   xmlns:bp="http://www.adk.gen/xmlns/blueprint">

    <!-- ============================================================ -->
    <!-- SENDER VARIANT (Kafka Consumer -> CPI)                       -->
    <!-- ============================================================ -->
    <Variant VariantName="Kafka_Adapter_Plus_Sender"
             VariantId="ctype::AdapterVariant/cname::kafkaAdapterPlus/vendor::FlorianKube/tp::cpi-kafka-plus/mp::cpi-kafka-plus/direction::Sender/version::1.0.3"
             MetadataVersion="2.0"
             gen:RuntimeComponentBaseUri="cpi-kafka-plus"
             AttachmentBehavior="Preserve"
             supportsPolling="true"
             useDefaultScheduler="false">
        <InputContent Cardinality="1" Scope="outsidepool" MessageCardinality="1" isStreaming="false">
            <Content>
                <ContentType>Any</ContentType>
                <Schema xsi:type="xs:string" xmlns:xs="http://www.w3.org/2001/XMLSchema" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"/>
            </Content>
        </InputContent>
        <OutputContent Cardinality="1" Scope="outsidepool" MessageCardinality="1" isStreaming="false">
            <Content>
                <ContentType>Any</ContentType>
                <Schema xsi:type="xs:string" xmlns:xs="http://www.w3.org/2001/XMLSchema" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"/>
            </Content>
        </OutputContent>

        <!-- ===== Tab: Connection ===== -->
        <Tab id="connection">
            <GuiLabels guid="a1000001-0000-0000-0000-000000000001">
                <Label language="EN">Connection</Label>
            </GuiLabels>
            <AttributeGroup id="kafkaConnection">
                <Name xsi:type="xs:string" xmlns:xs="http://www.w3.org/2001/XMLSchema" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance">Kafka Connection</Name>
                <GuiLabels guid="a1000001-0000-0000-0000-000000000010">
                    <Label language="EN">Kafka Connection</Label>
                </GuiLabels>
                <AttributeReference>
                    <ReferenceName>bootstrapServers</ReferenceName>
                    <description>Comma-separated list of Kafka bootstrap servers (host:port), e.g. broker1.example.com:9092,broker2.example.com:9092. For Confluent Cloud use the Bootstrap Server from your cluster settings.</description>
                    <ErrorMessage>Please enter at least one bootstrap server in host:port format (e.g. broker1:9092,broker2:9092)</ErrorMessage>
                </AttributeReference>
                <AttributeReference>
                    <ReferenceName>topic</ReferenceName>
                    <description>Kafka topic(s) to consume from. For multiple topics use comma-separated names, e.g. orders,payments. All topics must exist on the Kafka cluster.</description>
                    <ErrorMessage>Please enter at least one Kafka topic name</ErrorMessage>
                </AttributeReference>
                <AttributeReference>
                    <ReferenceName>groupId</ReferenceName>
                    <description>Consumer group ID, e.g. cpi-order-consumer. All adapter instances sharing the same group ID will split the partition load across them. Note: If multiple stages (e.g. DEV, QAS, PROD) connect to the same Kafka cluster, each stage must use a different consumer group ID (e.g. cpi-order-consumer-dev / -qas / -prod). Sharing one group ID across stages causes continuous rebalances and unstable consumption.</description>
                    <ErrorMessage>Please enter a consumer group ID (e.g. cpi-order-consumer)</ErrorMessage>
                </AttributeReference>
            </AttributeGroup>
            <AttributeGroup id="kafkaSecurity">
                <Name xsi:type="xs:string" xmlns:xs="http://www.w3.org/2001/XMLSchema" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance">Kafka Security</Name>
                <GuiLabels guid="a1000002-0000-0000-0000-000000000010">
                    <Label language="EN">Kafka Security</Label>
                </GuiLabels>
                <AttributeReference>
                    <ReferenceName>securityProtocol</ReferenceName>
                    <description>Security protocol for broker communication. Use SASL_SSL for Confluent Cloud or any broker requiring encrypted authentication.</description>
                </AttributeReference>
                <AttributeReference>
                    <ReferenceName>saslMechanism</ReferenceName>
                    <description>SASL authentication mechanism. Use PLAIN for Confluent Cloud (API Key/Secret). SCRAM-SHA-256/512 for self-managed Kafka clusters with SCRAM authentication.</description>
                </AttributeReference>
                <AttributeReference>
                    <ReferenceName>credentialAlias</ReferenceName>
                    <description>Name of the 'User Credentials' artifact deployed in CPI Security Material, e.g. kafka-credentials. Username = SASL username or API Key, Password = SASL password or API Secret.</description>
                    <ErrorMessage>Please enter the alias of a User Credentials artifact from CPI Security Material</ErrorMessage>
                </AttributeReference>
            </AttributeGroup>
        </Tab>

        <!-- ===== Tab: Processing ===== -->
        <Tab id="processing">
            <GuiLabels guid="a1000003-0000-0000-0000-000000000001">
                <Label language="EN">Processing</Label>
            </GuiLabels>
            <AttributeGroup id="consumerConfig">
                <Name xsi:type="xs:string" xmlns:xs="http://www.w3.org/2001/XMLSchema" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance">Consumer Settings</Name>
                <GuiLabels guid="a1000003-0000-0000-0000-000000000010">
                    <Label language="EN">Consumer Settings</Label>
                </GuiLabels>
                <AttributeReference>
                    <ReferenceName>autoOffsetReset</ReferenceName>
                    <description>What to do when no committed offset exists for the consumer group. 'Latest' skips existing messages and only reads new ones. 'Earliest' reads all available messages from the beginning.</description>
                </AttributeReference>
                <AttributeReference>
                    <ReferenceName>pollingIntervalSeconds</ReferenceName>
                    <description>Time in seconds between poll cycles. Each cycle fetches up to 'Max Poll Records' from Kafka. Range: 1 to 21600 (1 second to 6 hours). Default: 5 seconds. Whole-hour values align polls with predictable clock times: 3600=1h, 7200=2h, 10800=3h, 14400=4h, 18000=5h, 21600=6h. Values above 21600 are rejected at IFlow start because they would exceed the max.poll.interval.ms hard cap (6 h 10 min) and cause the Kafka consumer to leave its group between polls.</description>
                    <ErrorMessage>Please enter a number between 1 and 21600 (1 second to 6 hours)</ErrorMessage>
                </AttributeReference>
                <AttributeReference>
                    <ReferenceName>maxPollRecords</ReferenceName>
                    <description>Maximum number of records returned per Kafka poll() call. Higher values improve throughput but increase memory usage. Default: 500.</description>
                    <ErrorMessage>Please enter a positive number (e.g. 500)</ErrorMessage>
                </AttributeReference>
                <AttributeReference>
                    <ReferenceName>maxPartitionFetchSizeKb</ReferenceName>
                    <description>Maximum data the broker returns per partition per poll, in kilobytes. This controls how many records each poll() can fetch. Default: 1024 KB (1 MB) -- with 1 KB messages, that means ~1000 records per partition. Increase when 'Drain Backlog' is enabled and polls return far fewer records than 'Max Poll Records'. For example, set to 10240 (10 MB) to allow ~10,000 records of 1 KB per partition per poll. The actual number of records is limited by both this setting AND 'Max Poll Records' -- whichever is reached first wins. Note: This is a per-partition limit. The total fetch across all partitions is capped at 50 MB by Kafka's fetch.max.bytes default.</description>
                    <ErrorMessage>Please enter a value between 1 and 51200 (KB)</ErrorMessage>
                </AttributeReference>
                <AttributeReference>
                    <ReferenceName>drainEnabled</ReferenceName>
                    <description>Enable drain mode: after each poll cycle, continue polling until the topic is empty or the drain limit is reached. Recommended for topics with peak loads (e.g. month-end processing).</description>
                </AttributeReference>
                <AttributeReference>
                    <ReferenceName>minBacklogToDrain</ReferenceName>
                    <description>Minimum number of records a drain poll must return to keep draining. The first poll of a scheduled run always processes its records. On extra drain cycles (cycle &gt; 1), if a poll returns fewer records than this threshold, those records are seeked back (un-polled) and the drain stops, avoiding tiny tail MPLs. Set to 0 to drain until the topic is completely empty (default).</description>
                    <ErrorMessage>Please enter a non-negative number (e.g. 0, 100, 500)</ErrorMessage>
                    <EditCondition>
                        <AttributeName>drainEnabled</AttributeName>
                        <AttributeValue>true</AttributeValue>
                    </EditCondition>
                </AttributeReference>
                <AttributeReference>
                    <ReferenceName>commitStrategy</ReferenceName>
                    <description>When to commit offsets back to Kafka. 'After Successful Processing' ensures at-least-once delivery (recommended). 'Auto Commit' commits periodically regardless of processing success.</description>
                </AttributeReference>
            </AttributeGroup>
            <AttributeGroup id="jsonSchemaConfig">
                <Name xsi:type="xs:string" xmlns:xs="http://www.w3.org/2001/XMLSchema" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance">JSON Schema Validation</Name>
                <GuiLabels guid="a1000003-0000-0000-0000-000000000030">
                    <Label language="EN">JSON Schema Validation</Label>
                </GuiLabels>
                <AttributeReference>
                    <ReferenceName>jsonSchemaValidation</ReferenceName>
                    <description>Enable validation of incoming Kafka messages against a JSON Schema before they are passed to the IFlow. Invalid messages are skipped or reported based on error settings.</description>
                </AttributeReference>
                <AttributeReference>
                    <ReferenceName>jsonSchema</ReferenceName>
                    <description>Inline JSON Schema (draft-07) to validate messages against, e.g. {"type":"object","required":["id"],"properties":{"id":{"type":"string"}}}. Paste the full JSON Schema definition here.</description>
                    <EditCondition>
                        <AttributeName>jsonSchemaValidation</AttributeName>
                        <AttributeValue>true</AttributeValue>
                    </EditCondition>
                </AttributeReference>
                <AttributeReference>
                    <ReferenceName>jsonSchemaReportError</ReferenceName>
                    <description>Report validation failures as ERROR in CPI Monitoring (MPL)</description>
                    <EditCondition>
                        <AttributeName>jsonSchemaValidation</AttributeName>
                        <AttributeValue>true</AttributeValue>
                    </EditCondition>
                </AttributeReference>
            </AttributeGroup>
            <AttributeGroup id="batchConfig">
                <Name xsi:type="xs:string" xmlns:xs="http://www.w3.org/2001/XMLSchema" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance">Batch Settings</Name>
                <GuiLabels guid="a1000003-0000-0000-0000-000000000020">
                    <Label language="EN">Batch Settings</Label>
                </GuiLabels>
                <AttributeReference>
                    <ReferenceName>batchMode</ReferenceName>
                    <description>Enable batch mode to process multiple Kafka records in a single IFlow execution. Improves throughput for high-volume topics. Disable for single-message processing.</description>
                </AttributeReference>
                <AttributeReference>
                    <ReferenceName>batchSize</ReferenceName>
                    <description>Maximum number of records per batch. The adapter collects up to this many records before triggering the IFlow. Default: 100.</description>
                    <ErrorMessage>Please enter a positive number for batch size (e.g. 100)</ErrorMessage>
                    <EditCondition>
                        <AttributeName>batchMode</AttributeName>
                        <AttributeValue>true</AttributeValue>
                    </EditCondition>
                </AttributeReference>
                <AttributeReference>
                    <ReferenceName>batchTimeout</ReferenceName>
                    <description>Maximum time in milliseconds to wait for the batch to fill before triggering the IFlow. Default: 5000 (5 seconds). Increase for low-volume topics to collect more records per batch.</description>
                    <ErrorMessage>Please enter a positive number in milliseconds (e.g. 5000)</ErrorMessage>
                    <EditCondition>
                        <AttributeName>batchMode</AttributeName>
                        <AttributeValue>true</AttributeValue>
                    </EditCondition>
                </AttributeReference>
                <AttributeReference>
                    <ReferenceName>batchOutputFormat</ReferenceName>
                    <description>Output format for batched records. JSON Array: [{"key":"...","value":"..."},...]. XML List: wraps records in XML elements. Individual Exchanges: sends each record as a separate IFlow execution (no actual batching).</description>
                    <EditCondition>
                        <AttributeName>batchMode</AttributeName>
                        <AttributeValue>true</AttributeValue>
                    </EditCondition>
                </AttributeReference>
            </AttributeGroup>
        </Tab>

        <!-- ===== Tab: Avro / Schema Registry ===== -->
        <Tab id="avro">
            <GuiLabels guid="a1000004-0000-0000-0000-000000000001">
                <Label language="EN">Avro / Schema Registry</Label>
            </GuiLabels>
            <AttributeGroup id="schemaRegistryConfig">
                <Name xsi:type="xs:string" xmlns:xs="http://www.w3.org/2001/XMLSchema" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance">Schema Registry</Name>
                <GuiLabels guid="a1000004-0000-0000-0000-000000000010">
                    <Label language="EN">Schema Registry</Label>
                </GuiLabels>
                <AttributeReference>
                    <ReferenceName>schemaRegistryEnabled</ReferenceName>
                    <description>Enable Confluent Schema Registry integration for Avro serialization/deserialization.</description>
                </AttributeReference>
                <AttributeReference>
                    <ReferenceName>schemaRegistryUrl</ReferenceName>
                    <description>Confluent Schema Registry URL, e.g. https://schema-registry.example.com:8081. Required when Schema Registry is enabled. For Confluent Cloud use the Schema Registry endpoint from your environment settings.</description>
                    <ErrorMessage>Please enter a valid Schema Registry URL (e.g. https://schema-registry.example.com:8081)</ErrorMessage>
                    <EditCondition>
                        <AttributeName>schemaRegistryEnabled</AttributeName>
                        <AttributeValue>true</AttributeValue>
                    </EditCondition>
                </AttributeReference>
                <AttributeReference>
                    <ReferenceName>schemaRegistryCredentialAlias</ReferenceName>
                    <description>Name of the 'User Credentials' artifact in CPI Security Material for Schema Registry basic auth. Username = API Key, Password = API Secret. Leave empty if Schema Registry requires no authentication.</description>
                    <EditCondition>
                        <AttributeName>schemaRegistryEnabled</AttributeName>
                        <AttributeValue>true</AttributeValue>
                    </EditCondition>
                </AttributeReference>
                <AttributeReference>
                    <ReferenceName>avroOutputFormat</ReferenceName>
                    <description>Format for deserialized Avro records delivered to the IFlow. JSON: Avro records converted to JSON. XML: Avro records converted to XML.</description>
                    <EditCondition>
                        <AttributeName>schemaRegistryEnabled</AttributeName>
                        <AttributeValue>true</AttributeValue>
                    </EditCondition>
                </AttributeReference>
                <AttributeReference>
                    <ReferenceName>avroValueDeserialization</ReferenceName>
                    <description>Deserialize message values using Avro via Schema Registry. Enable when the Kafka producer sends Avro-encoded values.</description>
                    <EditCondition>
                        <AttributeName>schemaRegistryEnabled</AttributeName>
                        <AttributeValue>true</AttributeValue>
                    </EditCondition>
                </AttributeReference>
            </AttributeGroup>
        </Tab>

        <!-- ===== Tab: Error Handling ===== -->
        <Tab id="errorHandling">
            <GuiLabels guid="a1000005-0000-0000-0000-000000000001">
                <Label language="EN">Error Handling</Label>
            </GuiLabels>
            <AttributeGroup id="dlqConfig">
                <Name xsi:type="xs:string" xmlns:xs="http://www.w3.org/2001/XMLSchema" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance">Dead Letter Queue</Name>
                <GuiLabels guid="a1000005-0000-0000-0000-000000000010">
                    <Label language="EN">Dead Letter Queue</Label>
                </GuiLabels>
                <AttributeReference>
                    <ReferenceName>dlqEnabled</ReferenceName>
                    <description>Enable Dead Letter Queue (DLQ). Failed messages are routed to a separate Kafka topic instead of blocking the consumer. Recommended for production use.</description>
                </AttributeReference>
                <AttributeReference>
                    <ReferenceName>dlqTopic</ReferenceName>
                    <description>Kafka topic for failed messages, e.g. orders-dlq or my-topic.DLQ. This topic must exist on the Kafka cluster. Convention: use the source topic name with a -dlq or .DLQ suffix.</description>
                    <ErrorMessage>Please enter the name of the Dead Letter Queue topic (e.g. my-topic-dlq)</ErrorMessage>
                    <EditCondition>
                        <AttributeName>dlqEnabled</AttributeName>
                        <AttributeValue>true</AttributeValue>
                    </EditCondition>
                </AttributeReference>
                <AttributeReference>
                    <ReferenceName>dlqMaxRetries</ReferenceName>
                    <description>Number of processing retries before a message is routed to the DLQ. Default: 3. Set to 0 to route failed messages immediately without retrying.</description>
                    <ErrorMessage>Please enter a non-negative number (e.g. 3)</ErrorMessage>
                    <EditCondition>
                        <AttributeName>dlqEnabled</AttributeName>
                        <AttributeValue>true</AttributeValue>
                    </EditCondition>
                </AttributeReference>
                <AttributeReference>
                    <ReferenceName>dlqCredentialAlias</ReferenceName>
                    <description>User Credentials alias for the DLQ Kafka cluster. Leave empty to reuse the main SASL credentials from the Connection tab. Only needed if the DLQ topic is on a different cluster.</description>
                    <EditCondition>
                        <AttributeName>dlqEnabled</AttributeName>
                        <AttributeValue>true</AttributeValue>
                    </EditCondition>
                </AttributeReference>
                <AttributeReference>
                    <ReferenceName>retryOnlyTransientErrors</ReferenceName>
                    <description>Only retry transient errors (e.g. timeouts, connection failures). Permanent errors like mapping failures or NullPointerExceptions are sent directly to the DLQ without retries. This avoids unnecessary retry attempts and MPL entries for errors that will never succeed. Disable this to retry all errors regardless of type.</description>
                    <EditCondition>
                        <AttributeName>dlqEnabled</AttributeName>
                        <AttributeValue>true</AttributeValue>
                    </EditCondition>
                </AttributeReference>
                <AttributeReference>
                    <ReferenceName>retryDelaySeconds</ReferenceName>
                    <description>Initial delay between retries in seconds. The delay doubles after each retry attempt (exponential backoff), capped at 300 seconds. For example, with a delay of 2 seconds and 3 retries, the consumer waits 2s after the first failure, 4s after the second, and 8s after the third (14s total). This gives downstream systems time to recover from transient failures. Set to 0 to retry immediately without delay.</description>
                    <ErrorMessage>Please enter a number of seconds between 0 and 300 (e.g. 2)</ErrorMessage>
                    <EditCondition>
                        <AttributeName>dlqEnabled</AttributeName>
                        <AttributeValue>true</AttributeValue>
                    </EditCondition>
                </AttributeReference>
            </AttributeGroup>
            <AttributeGroup id="autoPauseConfig">
                <Name xsi:type="xs:string" xmlns:xs="http://www.w3.org/2001/XMLSchema" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance">Auto-Pause on Errors</Name>
                <GuiLabels guid="a1000005-0000-0000-0000-000000000020">
                    <Label language="EN">Auto-Pause on Errors</Label>
                </GuiLabels>
                <AttributeReference>
                    <ReferenceName>autoPauseEnabled</ReferenceName>
                    <description>Enable automatic consumer pause after consecutive processing errors. Protects downstream systems from overload when a backend is unavailable. Recommended for production use.</description>
                </AttributeReference>
                <AttributeReference>
                    <ReferenceName>autoPauseErrorThreshold</ReferenceName>
                    <description>Number of consecutive processing errors before the consumer pauses. Default: 5.</description>
                    <ErrorMessage>Please enter a positive number (e.g. 5)</ErrorMessage>
                    <EditCondition>
                        <AttributeName>autoPauseEnabled</AttributeName>
                        <AttributeValue>true</AttributeValue>
                    </EditCondition>
                </AttributeReference>
                <AttributeReference>
                    <ReferenceName>autoPauseCooldownSeconds</ReferenceName>
                    <description>Initial pause duration in seconds. The pause doubles after each subsequent failure (60s, 120s, 240s, max 900s / 15 min). Default: 60.</description>
                    <ErrorMessage>Please enter a positive number in seconds (e.g. 60)</ErrorMessage>
                    <EditCondition>
                        <AttributeName>autoPauseEnabled</AttributeName>
                        <AttributeValue>true</AttributeValue>
                    </EditCondition>
                </AttributeReference>
            </AttributeGroup>
        </Tab>

    </Variant>


