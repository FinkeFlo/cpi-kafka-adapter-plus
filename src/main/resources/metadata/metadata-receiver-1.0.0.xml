                   ComponentName="kafkaAdapterPlus"
                   UIElementType="Adapter"
                   IsExtension="false"
                   IsFinal="true"
                   IsPreserves="true"
                   IsDefaultGenerator="true"
                   ComponentDisplayName="KafkaAdapterPlus"
                   xmlns:gen="http://www.sap.hci.adk.com/gen"
                   xmlns:bp="http://www.adk.gen/xmlns/blueprint">

    <!-- ============================================================ -->
    <!-- RECEIVER VARIANT (CPI -> Kafka Producer)                    -->
    <!-- ============================================================ -->
    <Variant VariantName="Kafka_Adapter_Plus_Receiver"
             VariantId="ctype::AdapterVariant/cname::kafkaAdapterPlus/vendor::FlorianKube/tp::cpi-kafka-plus/mp::cpi-kafka-plus/direction::Receiver/version::1.0.7"
             MetadataVersion="2.0"
             gen:RuntimeComponentBaseUri="cpi-kafka-plus"
             AttachmentBehavior="Preserve"
             supportsPolling="false"
             IsRequestResponse="true">
        <InputContent Cardinality="1" Scope="outsidepool" MessageCardinality="1" isStreaming="false">
            <Content>
                <ContentType>Any</ContentType>
                <Schema xsi:type="xs:string" xmlns:xs="http://www.w3.org/2001/XMLSchema" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"/>
            </Content>
        </InputContent>
        <OutputContent Cardinality="1" Scope="outsidepool" MessageCardinality="1" isStreaming="false">
            <Content>
                <ContentType>Any</ContentType>
                <Schema xsi:type="xs:string" xmlns:xs="http://www.w3.org/2001/XMLSchema" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"/>
            </Content>
        </OutputContent>

        <!-- ===== Tab: Connection ===== -->
        <Tab id="connection">
            <GuiLabels guid="a2000001-0000-0000-0000-000000000001">
                <Label language="EN">Connection</Label>
            </GuiLabels>
            <AttributeGroup id="kafkaConnection">
                <Name xsi:type="xs:string" xmlns:xs="http://www.w3.org/2001/XMLSchema" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance">Kafka Connection</Name>
                <GuiLabels guid="a2000001-0000-0000-0000-000000000010">
                    <Label language="EN">Kafka Connection</Label>
                </GuiLabels>
                <AttributeReference>
                    <ReferenceName>bootstrapServers</ReferenceName>
                    <description>Comma-separated list of Kafka bootstrap servers (host:port), e.g. broker1.example.com:9092,broker2.example.com:9092. For Confluent Cloud use the Bootstrap Server from your cluster settings.</description>
                    <ErrorMessage>Please enter at least one bootstrap server in host:port format (e.g. broker1:9092,broker2:9092)</ErrorMessage>
                </AttributeReference>
                <AttributeReference>
                    <ReferenceName>topic</ReferenceName>
                    <description>Kafka topic to produce messages to, e.g. orders-outbound. The topic must exist on the Kafka cluster unless auto-creation is enabled on the broker.</description>
                    <ErrorMessage>Please enter a Kafka topic name</ErrorMessage>
                </AttributeReference>
            </AttributeGroup>
            <AttributeGroup id="kafkaSecurity">
                <Name xsi:type="xs:string" xmlns:xs="http://www.w3.org/2001/XMLSchema" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance">Kafka Security</Name>
                <GuiLabels guid="a2000002-0000-0000-0000-000000000010">
                    <Label language="EN">Kafka Security</Label>
                </GuiLabels>
                <AttributeReference>
                    <ReferenceName>securityProtocol</ReferenceName>
                    <description>Security protocol for broker communication. Use SASL_SSL for Confluent Cloud or any broker requiring encrypted authentication.</description>
                </AttributeReference>
                <AttributeReference>
                    <ReferenceName>saslMechanism</ReferenceName>
                    <description>SASL authentication mechanism. Use PLAIN for Confluent Cloud (API Key/Secret). SCRAM-SHA-256/512 for self-managed Kafka clusters with SCRAM authentication.</description>
                </AttributeReference>
                <AttributeReference>
                    <ReferenceName>credentialAlias</ReferenceName>
                    <description>Name of the 'User Credentials' artifact deployed in CPI Security Material, e.g. kafka-credentials. Username = SASL username or API Key, Password = SASL password or API Secret. Required when Security Protocol is SASL_SSL or SASL_PLAINTEXT.</description>
                    <Restriction>Constraint.isValidRegex(.+)</Restriction>
                    <ErrorMessage>Please enter the alias of a User Credentials artifact from CPI Security Material</ErrorMessage>
                    <OrCondition>
                        <EditCondition>
                            <AttributeName>securityProtocol</AttributeName>
                            <AttributeValue>SASL_SSL</AttributeValue>
                        </EditCondition>
                        <EditCondition>
                            <AttributeName>securityProtocol</AttributeName>
                            <AttributeValue>SASL_PLAINTEXT</AttributeValue>
                        </EditCondition>
                    </OrCondition>
                </AttributeReference>
                <AttributeReference>
                    <ReferenceName>sslKeystoreAlias</ReferenceName>
                    <description>Optional CPI Keystore alias for custom broker CAs and/or client certificates (mTLS). Leave empty for publicly trusted brokers that work with the JVM default truststore.</description>
                    <OrCondition>
                        <EditCondition>
                            <AttributeName>securityProtocol</AttributeName>
                            <AttributeValue>SASL_SSL</AttributeValue>
                        </EditCondition>
                        <EditCondition>
                            <AttributeName>securityProtocol</AttributeName>
                            <AttributeValue>SSL</AttributeValue>
                        </EditCondition>
                    </OrCondition>
                </AttributeReference>
            </AttributeGroup>
        </Tab>

        <!-- ===== Tab: Producer Settings ===== -->
        <Tab id="producerSettings">
            <GuiLabels guid="a2000003-0000-0000-0000-000000000001">
                <Label language="EN">Producer Settings</Label>
            </GuiLabels>
            <AttributeGroup id="producerSending">
                <Name xsi:type="xs:string" xmlns:xs="http://www.w3.org/2001/XMLSchema" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance">Sending</Name>
                <GuiLabels guid="a2000003-0000-0000-0000-000000000010">
                    <Label language="EN">Sending</Label>
                </GuiLabels>
                <AttributeReference>
                    <ReferenceName>producerBatchMode</ReferenceName>
                    <description>Select how a structured message body (JSON array or XML list) is split into individual Kafka records. NONE sends the entire message body as one record. JSON_ARRAY expects a JSON array of record objects. XML_LIST expects an XML document with root element kafkaRecords containing record elements.</description>
                </AttributeReference>
                <AttributeReference>
                    <ReferenceName>acks</ReferenceName>
                    <description>Producer acknowledgment level. 'All': waits for all in-sync replicas (strongest durability, recommended). 'Leader Only': waits for leader only. 'None': fire and forget, no durability guarantee.</description>
                    <EditCondition>
                        <AttributeName>enableIdempotence</AttributeName>
                        <AttributeValue>false</AttributeValue>
                    </EditCondition>
                </AttributeReference>
                <AttributeReference>
                    <ReferenceName>compressionType</ReferenceName>
                    <description>Compression algorithm for message batches. Reduces network bandwidth and storage at the cost of CPU. ZSTD is recommended for JSON payloads (best ratio with good speed). LZ4 is the fastest with minimal CPU overhead. GZIP achieves the smallest output but is the slowest. None disables compression entirely.</description>
                </AttributeReference>
                <AttributeReference>
                    <ReferenceName>enableIdempotence</ReferenceName>
                    <description>Enable idempotent producer to guarantee exactly-once delivery per partition. Prevents duplicate messages on retries. Recommended to keep enabled (default: true).</description>
                </AttributeReference>
                <AttributeReference>
                    <ReferenceName>deliveryTimeoutSeconds</ReferenceName>
                    <description>Maximum time in seconds for message delivery, including retries. Default: 120 seconds (2 minutes). If delivery fails within this time, the send is reported as failed.</description>
                    <ErrorMessage>Please enter a positive number in seconds (e.g. 120 for 2 minutes)</ErrorMessage>
                </AttributeReference>
            </AttributeGroup>
            <AttributeGroup id="producerPerformance">
                <Name xsi:type="xs:string" xmlns:xs="http://www.w3.org/2001/XMLSchema" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance">Performance Tuning</Name>
                <GuiLabels guid="a2000003-0000-0000-0000-000000000011">
                    <Label language="EN">Performance Tuning</Label>
                </GuiLabels>
                <AttributeReference>
                    <ReferenceName>maxRequestSizeKb</ReferenceName>
                    <description>Maximum size of a single produce request in kilobytes. Default: 5120 KB (5 MB). Increase if your messages exceed 5 MB. Must also be allowed by the broker's message.max.bytes setting.</description>
                    <ErrorMessage>Please enter a positive number in KB (e.g. 5120 for 5 MB)</ErrorMessage>
                </AttributeReference>
                <AttributeReference>
                    <ReferenceName>producerBatchSizeKb</ReferenceName>
                    <description>Maximum size of a producer batch in kilobytes. Default: 1024 KB (1 MB). The producer groups records into batches per partition for efficiency.</description>
                    <ErrorMessage>Please enter a positive number in KB (e.g. 1024 for 1 MB)</ErrorMessage>
                </AttributeReference>
                <AttributeReference>
                    <ReferenceName>bufferMemoryKb</ReferenceName>
                    <description>Total memory in kilobytes available for buffering unsent records. Default: 32768 KB (32 MB). If the buffer is full, the producer blocks until space is available or delivery.timeout.ms is exceeded.</description>
                    <ErrorMessage>Please enter a positive number in KB (e.g. 32768 for 32 MB)</ErrorMessage>
                </AttributeReference>
            </AttributeGroup>
        </Tab>

        <!-- ===== Tab: Avro / Schema Registry ===== -->
        <Tab id="avro">
            <GuiLabels guid="a2000004-0000-0000-0000-000000000001">
                <Label language="EN">Avro / Schema Registry</Label>
            </GuiLabels>
            <AttributeGroup id="schemaRegistryConfig">
                <Name xsi:type="xs:string" xmlns:xs="http://www.w3.org/2001/XMLSchema" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance">Schema Registry</Name>
                <GuiLabels guid="a2000004-0000-0000-0000-000000000010">
                    <Label language="EN">Schema Registry</Label>
                </GuiLabels>
                <AttributeReference>
                    <ReferenceName>schemaRegistryEnabled</ReferenceName>
                    <description>Enable Confluent Schema Registry integration for Avro serialization/deserialization.</description>
                </AttributeReference>
                <AttributeReference>
                    <ReferenceName>schemaRegistryUrl</ReferenceName>
                    <description>Confluent Schema Registry URL, e.g. https://schema-registry.example.com:8081. Required when Schema Registry is enabled. For Confluent Cloud use the Schema Registry endpoint from your environment settings.</description>
                    <ErrorMessage>Please enter a valid Schema Registry URL (e.g. https://schema-registry.example.com:8081)</ErrorMessage>
                    <EditCondition>
                        <AttributeName>schemaRegistryEnabled</AttributeName>
                        <AttributeValue>true</AttributeValue>
                    </EditCondition>
                </AttributeReference>
                <AttributeReference>
                    <ReferenceName>schemaRegistryCredentialAlias</ReferenceName>
                    <description>Name of the 'User Credentials' artifact in CPI Security Material for Schema Registry basic auth. Username = API Key, Password = API Secret. Leave empty if Schema Registry requires no authentication.</description>
                    <EditCondition>
                        <AttributeName>schemaRegistryEnabled</AttributeName>
                        <AttributeValue>true</AttributeValue>
                    </EditCondition>
                </AttributeReference>
                <AttributeReference>
                    <ReferenceName>autoRegisterSchemas</ReferenceName>
                    <description>Automatically register new schemas with Schema Registry on first use. Requires write access to the registry. Recommended only for development. Disable in production and register schemas explicitly.</description>
                    <EditCondition>
                        <AttributeName>schemaRegistryEnabled</AttributeName>
                        <AttributeValue>true</AttributeValue>
                    </EditCondition>
                </AttributeReference>
                <AttributeReference>
                    <ReferenceName>subjectNameStrategy</ReferenceName>
                    <description>Strategy for deriving the Schema Registry subject name. TopicNameStrategy (default): uses topic name. RecordNameStrategy: uses the Avro record's full name. TopicRecordNameStrategy: combines both.</description>
                    <EditCondition>
                        <AttributeName>schemaRegistryEnabled</AttributeName>
                        <AttributeValue>true</AttributeValue>
                    </EditCondition>
                </AttributeReference>
                <AttributeReference>
                    <ReferenceName>avroValueSerialization</ReferenceName>
                    <description>Serialize message values using Avro via Schema Registry. Enable when the Kafka consumer expects Avro-encoded values.</description>
                    <EditCondition>
                        <AttributeName>schemaRegistryEnabled</AttributeName>
                        <AttributeValue>true</AttributeValue>
                    </EditCondition>
                </AttributeReference>
            </AttributeGroup>
        </Tab>

        <!-- ===== Tab: Processing (Receiver) ===== -->
        <Tab id="receiverProcessing">
            <GuiLabels guid="a2000005-0000-0000-0000-000000000001">
                <Label language="EN">Processing</Label>
            </GuiLabels>
            <AttributeGroup id="receiverJsonSchemaConfig">
                <Name xsi:type="xs:string" xmlns:xs="http://www.w3.org/2001/XMLSchema" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance">JSON Schema Validation</Name>
                <GuiLabels guid="a2000005-0000-0000-0000-000000000010">
                    <Label language="EN">JSON Schema Validation</Label>
                </GuiLabels>
                <AttributeReference>
                    <ReferenceName>jsonSchemaValidation</ReferenceName>
                    <description>Enable JSON Schema validation of outbound messages before sending to Kafka. Invalid messages are rejected with an error instead of being published.</description>
                </AttributeReference>
                <AttributeReference>
                    <ReferenceName>jsonSchema</ReferenceName>
                    <description>Inline JSON Schema (draft-07) to validate messages against, e.g. {"type":"object","required":["id"],"properties":{"id":{"type":"string"}}}. Paste the full JSON Schema definition here.</description>
                    <EditCondition>
                        <AttributeName>jsonSchemaValidation</AttributeName>
                        <AttributeValue>true</AttributeValue>
                    </EditCondition>
                </AttributeReference>
                <AttributeReference>
                    <ReferenceName>jsonSchemaReportError</ReferenceName>
                    <description>Report validation failures as ERROR in CPI Monitoring (MPL)</description>
                    <EditCondition>
                        <AttributeName>jsonSchemaValidation</AttributeName>
                        <AttributeValue>true</AttributeValue>
                    </EditCondition>
                </AttributeReference>
            </AttributeGroup>
        </Tab>

    </Variant>

